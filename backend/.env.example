# Copy to .env and fill in. Every variable is OPTIONAL — the server runs
# without any of them, degrading per service:
#   no ANTHROPIC_API_KEY → free layers + rule-based verdict
#   no SUPABASE_*        → in-memory cache, no auth/history
#   no UPSTASH_*         → in-process rate limiting (resets on restart)

# --- Anthropic (Claude L4 vision + L5 verdict) ---------------------------
# Console: https://platform.claude.com → Settings → API keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Gemini (free-tier alternative for L4/L5) -----------------------------
# Google AI Studio: https://aistudio.google.com → Get API key
# Claude is preferred when both keys are set.
GEMINI_API_KEY=AIza...

# --- Supabase (persistent cache + auth + history) ------------------------
# Dashboard: https://supabase.com/dashboard → your project → Settings → API
# Run supabase_schema.sql in the SQL editor first.
# SERVICE KEY = "service_role" secret — server-side only, never ship to the app.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# --- Upstash Redis REST (rate limiting across instances) -----------------
# Console: https://console.upstash.com → your Redis DB → REST API
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# --- Limits (defaults shown; ARCHITECTURE.md §5) --------------------------
# RATE_LIMIT_ANON_DAILY=5
# RATE_LIMIT_USER_DAILY=25
# CLAUDE_DAILY_CALL_BUDGET=1000
