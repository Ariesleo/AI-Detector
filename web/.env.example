# Backend API base URL. Defaults to http://127.0.0.1:8000 when unset.
VITE_API_URL=http://127.0.0.1:8000

# Supabase auth (sign-in + history). Browser-safe PUBLISHABLE key — never the
# secret/service key. Dashboard → Settings → API Keys → "Publishable key".
# Leave unset to run anonymous-only.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
